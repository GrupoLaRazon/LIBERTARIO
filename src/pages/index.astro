---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/navigation';
import { getPublishedArticles, getFeaturedArticle } from '@/utils/articles';
import { getCategoryLabel } from '@/data/categories';
import type { Category } from '@/data/categories';
 
const featured = await getFeaturedArticle();
const articles = await getPublishedArticles();
const rest = articles.filter((a) => a.slug !== featured?.slug);
 
const topStrip  = rest.slice(0, 3);   // tira superior
const sidebar   = rest.slice(3, 7);   // columna lateral
const bottomRow = rest.slice(7, 11);  // fila de 4 con imagen
const section2  = rest.slice(11, 14); // sección Titulares
const section3  = rest.slice(14, 17); // sección Policiales
const section4  = rest.slice(17, 20); // sección Mundo
const section5  = rest.slice(20, 23); // sección Actualidad
const section6  = rest.slice(23, 29); // noticias breves
---
 
<BaseLayout title={siteConfig.name} description={siteConfig.description}>
 
  <!-- ══ TIRA SUPERIOR: 3 noticias rápidas ══ -->
  {topStrip.length > 0 && (
    <section class="top-strip" aria-label="Noticias rápidas">
      {topStrip.map((article) => (
        <a href={`/articulo/${article.slug}/`} class="strip-item">
          <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
          <h3 class="strip-title">{article.data.title}</h3>
        </a>
      ))}
    </section>
  )}
 
  <!-- ══ FILA PRINCIPAL: hero + columna lateral ══ -->
  <section class="main-row" aria-label="Portada principal">
    {featured && (
      <article class="main-story">
        <a href={`/articulo/${featured.slug}/`} class="main-link">
          {featured.data.image ? (
            <img src={featured.data.image.src} alt={featured.data.image.alt} class="main-img" loading="eager" />
          ) : (
            <div class="img-ph main-img" aria-hidden="true">Imagen</div>
          )}
          <div class="main-content">
            <span class="badge">Titulares · {getCategoryLabel(featured.data.category as Category)}</span>
            <h1 class="main-title">{featured.data.title}</h1>
            <p class="main-desc">{featured.data.description}</p>
            <div class="meta">
              <span>Por {featured.data.author}</span>
              <span class="sep">|</span>
              <time datetime={featured.data.pubDate.toISOString()}>
                {featured.data.pubDate.toLocaleDateString('es-PE', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </div>
          </div>
        </a>
      </article>
    )}
    <aside class="side-col" aria-label="Noticias destacadas">
      {sidebar.map((article) => (
        <a href={`/articulo/${article.slug}/`} class="side-item">
          <div class="side-text">
            <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
            <h3 class="side-title">{article.data.title}</h3>
          </div>
          {article.data.image && (
            <img src={article.data.image.src} alt={article.data.image.alt} class="side-img" loading="lazy" />
          )}
        </a>
      ))}
    </aside>
  </section>
 
  <!-- ══ FILA INFERIOR: 4 noticias con imagen ══ -->
  {bottomRow.length > 0 && (
    <section class="bottom-row" aria-label="Más noticias">
      <div class="section-header"><span class="section-label">Más noticias</span></div>
      <div class="grid-4">
        {bottomRow.map((article) => (
          <a href={`/articulo/${article.slug}/`} class="grid-card">
            {article.data.image ? (
              <img src={article.data.image.src} alt={article.data.image.alt} class="card-img" loading="lazy" />
            ) : (
              <div class="img-ph card-img" aria-hidden="true">Foto</div>
            )}
            <div class="card-body">
              <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
              <h3 class="card-title">{article.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
 
  <!-- ══ SECCIÓN TITULARES ══ -->
  {section2.length > 0 && (
    <section class="news-section" aria-label="Titulares">
      <div class="section-header">
        <span class="section-label">Titulares</span>
        <a href="/titulares/" class="section-more">Ver todos →</a>
      </div>
      <div class="grid-3">
        {section2.map((article) => (
          <a href={`/articulo/${article.slug}/`} class="grid-card">
            {article.data.image ? (
              <img src={article.data.image.src} alt={article.data.image.alt} class="card-img" loading="lazy" />
            ) : (
              <div class="img-ph card-img" aria-hidden="true">Foto</div>
            )}
            <div class="card-body">
              <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
              <h3 class="card-title">{article.data.title}</h3>
              {article.data.description && <p class="card-desc">{article.data.description}</p>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
 
  <!-- ══ SECCIÓN POLICIALES ══ -->
  {section3.length > 0 && (
    <section class="news-section" aria-label="Policiales">
      <div class="section-header">
        <span class="section-label">Policiales</span>
        <a href="/policiales/" class="section-more">Ver todos →</a>
      </div>
      <div class="grid-3">
        {section3.map((article) => (
          <a href={`/articulo/${article.slug}/`} class="grid-card">
            {article.data.image ? (
              <img src={article.data.image.src} alt={article.data.image.alt} class="card-img" loading="lazy" />
            ) : (
              <div class="img-ph card-img" aria-hidden="true">Foto</div>
            )}
            <div class="card-body">
              <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
              <h3 class="card-title">{article.data.title}</h3>
              {article.data.description && <p class="card-desc">{article.data.description}</p>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
 
  <!-- ══ MUNDO + ACTUALIDAD: dos columnas ══ -->
  {(section4.length > 0 || section5.length > 0) && (
    <section class="two-col-section" aria-label="Mundo y Actualidad">
      {section4.length > 0 && (
        <div class="two-col-block">
          <div class="section-header">
            <span class="section-label">Mundo</span>
            <a href="/mundo/" class="section-more">Ver todos →</a>
          </div>
          {section4.map((article) => (
            <a href={`/articulo/${article.slug}/`} class="list-item">
              {article.data.image && (
                <img src={article.data.image.src} alt={article.data.image.alt} class="list-img" loading="lazy" />
              )}
              <div class="list-text">
                <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
                <h3 class="list-title">{article.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      )}
      {section5.length > 0 && (
        <div class="two-col-block">
          <div class="section-header">
            <span class="section-label">Actualidad</span>
            <a href="/actualidad/" class="section-more">Ver todos →</a>
          </div>
          {section5.map((article) => (
            <a href={`/articulo/${article.slug}/`} class="list-item">
              {article.data.image && (
                <img src={article.data.image.src} alt={article.data.image.alt} class="list-img" loading="lazy" />
              )}
              <div class="list-text">
                <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
                <h3 class="list-title">{article.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  )}
 
  <!-- ══ NOTICIAS BREVES ══ -->
  {section6.length > 0 && (
    <section class="news-section" aria-label="Noticias breves">
      <div class="section-header"><span class="section-label">Noticias breves</span></div>
      <div class="briefs-grid">
        {section6.map((article) => (
          <a href={`/articulo/${article.slug}/`} class="brief-item">
            <span class="cat-label">{getCategoryLabel(article.data.category as Category)}</span>
            <h3 class="brief-title">{article.data.title}</h3>
            {article.data.description && <p class="brief-desc">{article.data.description}</p>}
          </a>
        ))}
      </div>
    </section>
  )}
 
</BaseLayout>
 
<style>
  /* ── Utilidades base ── */
  .cat-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #1a3f8f;
    margin-bottom: 4px;
  }
  .sep { color: #ccc; }
  .img-ph {
    background: repeating-linear-gradient(45deg, #ddd, #ddd 4px, #eee 4px, #eee 12px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #aaa;
    letter-spacing: 0.05em;
  }
 
  /* ── Cabeceras de sección ── */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #1a3f8f;
    padding-bottom: 5px;
    margin-bottom: 12px;
  }
  .section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1a3f8f;
  }
  .section-more {
    font-size: 0.7rem;
    color: #888;
    text-decoration: none;
  }
  .section-more:hover { color: #1a3f8f; }
  .news-section { margin-bottom: 28px; }
 
  /* ── Tira superior ── */
  .top-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 2px solid #111;
    margin-bottom: 12px;
  }
  .strip-item {
    padding: 10px 14px;
    border-right: 1px solid #ddd;
    text-decoration: none;
    display: block;
    transition: background 0.15s;
  }
  .strip-item:last-child { border-right: none; }
  .strip-item:hover { background: #f5f7ff; }
  .strip-title { font-size: 0.8rem; font-weight: 700; color: #111; line-height: 1.35; }
 
  /* ── Fila principal ── */
  .main-row {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 12px;
    margin-bottom: 20px;
  }
  .main-story { border: 2px solid #111; background: #fff; }
  .main-link { display: block; text-decoration: none; color: inherit; }
  .main-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; border-bottom: 2px solid #111; }
  .main-content { padding: 16px 20px 20px; }
  .badge {
    display: inline-block;
    background: #1a3f8f;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    margin-bottom: 10px;
  }
  .main-title { font-size: 1.6rem; font-weight: 900; color: #111; line-height: 1.15; margin-bottom: 8px; font-family: Georgia, serif; }
  .main-desc { font-size: 0.9rem; color: #444; line-height: 1.5; margin-bottom: 10px; }
  .meta { font-size: 0.75rem; color: #888; display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
 
  /* Columna lateral */
  .side-col { display: flex; flex-direction: column; border: 1px solid #ddd; background: #fff; }
  .side-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-left: 3px solid #1a3f8f;
    border-bottom: 1px solid #eee;
    text-decoration: none;
    transition: background 0.15s;
    flex: 1;
  }
  .side-item:last-child { border-bottom: none; }
  .side-item:hover { background: #f5f7ff; }
  .side-text { flex: 1; }
  .side-title { font-size: 0.8rem; font-weight: 700; color: #111; line-height: 1.35; margin-top: 4px; }
  .side-img { width: 72px; height: 56px; object-fit: cover; flex-shrink: 0; border: 1px solid #eee; }
 
  /* ── Grid 4 columnas ── */
  .bottom-row { margin-bottom: 28px; }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
 
  /* ── Grid 3 columnas ── */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
 
  /* Tarjeta genérica */
  .grid-card { text-decoration: none; display: block; background: #fff; border: 1px solid #e0e0e0; transition: box-shadow 0.15s; }
  .grid-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  .card-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .card-body { padding: 10px 12px 14px; }
  .card-title { font-size: 0.82rem; font-weight: 700; color: #111; line-height: 1.35; margin-top: 4px; }
  .card-desc { font-size: 0.75rem; color: #666; line-height: 1.4; margin-top: 5px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
 
  /* ── Dos columnas mundo + actualidad ── */
  .two-col-section { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-bottom: 28px; }
  .list-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    padding: 10px 0;
    border-bottom: 1px solid #eee;
    text-decoration: none;
    transition: background 0.15s;
  }
  .list-item:last-child { border-bottom: none; }
  .list-item:hover { background: #f5f7ff; }
  .list-img { width: 80px; height: 60px; object-fit: cover; flex-shrink: 0; border: 1px solid #eee; }
  .list-text { flex: 1; }
  .list-title { font-size: 0.82rem; font-weight: 700; color: #111; line-height: 1.35; margin-top: 3px; }
 
  /* ── Noticias breves ── */
  .briefs-grid { display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid #e0e0e0; }
  .brief-item {
    padding: 14px 16px;
    border-right: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
    text-decoration: none;
    display: block;
    transition: background 0.15s;
  }
  .brief-item:nth-child(3n) { border-right: none; }
  .brief-item:hover { background: #f5f7ff; }
  .brief-title { font-size: 0.82rem; font-weight: 700; color: #111; line-height: 1.35; margin-top: 3px; }
  .brief-desc { font-size: 0.73rem; color: #666; line-height: 1.4; margin-top: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
 
  /* ── Responsive ── */
  @media (max-width: 900px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
    .two-col-section { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .top-strip { grid-template-columns: 1fr; }
    .strip-item { border-right: none; border-bottom: 1px solid #ddd; }
    .main-row { grid-template-columns: 1fr; }
    .grid-3 { grid-template-columns: 1fr 1fr; }
    .briefs-grid { grid-template-columns: 1fr 1fr; }
    .main-title { font-size: 1.25rem; }
  }
  @media (max-width: 480px) {
    .grid-3 { grid-template-columns: 1fr; }
    .grid-4 { grid-template-columns: 1fr; }
    .briefs-grid { grid-template-columns: 1fr; }
    .brief-item:nth-child(3n) { border-right: 1px solid #e0e0e0; }
  }
</style>