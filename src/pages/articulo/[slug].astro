---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCategoryLabel } from '@/data/categories';
import type { Category } from '@/data/categories';

export async function getStaticPaths() {
  const articles = await getCollection('articulos', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, description, pubDate, author, category, image } = article.data;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={pubDate.toISOString()}
  author={author}
  image={image?.src}
>
  <article class="mx-auto max-w-3xl">
    <header class="mb-8 border-b-2 border-black pb-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-libertario-blue">
        {getCategoryLabel(category as Category)}
      </p>
      <h1 class="mt-3 font-serif text-3xl font-bold leading-tight md:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-libertario-muted">{description}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-libertario-muted">
        <span>Por <strong class="text-libertario-dark">{author}</strong></span>
        <span class="text-gray-300">·</span>
        <time datetime={pubDate.toISOString()}>
          {
            pubDate.toLocaleDateString('es-PE', {
              weekday: 'long',
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })
          }
        </time>
      </div>
    </header>

    {
      image && (
        <img
          src={image.src}
          alt={image.alt}
          class="mb-8 aspect-video w-full border-2 border-black object-cover"
        />
      )
    }

    <div class="article-content">
      <Content />
    </div>
  </article>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      headline: title,
      description,
      datePublished: pubDate.toISOString(),
      author: { '@type': 'Person', name: author },
      inLanguage: 'es-PE',
      isAccessibleForFree: true,
    })}
  />
</BaseLayout>
