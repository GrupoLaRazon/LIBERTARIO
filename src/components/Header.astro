---
// src/components/Header.astro

const navLinks = [
  { href: '/titulares/', label: 'Titulares' },
  { href: '/policiales/', label: 'Policiales' },
  { href: '/actualidad/', label: 'Actualidad' },
  { href: '/mundo/', label: 'Mundo' },
  { href: '/mas/', label: 'Más' },
];

const currentPath = Astro.url.pathname;
---

<header>
  <!-- Barra superior: nav + fecha/clima -->
  <div class="topnav">
    <nav aria-label="Secciones principales">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="topnav-right">
      <span id="fecha-dinamica">cargando...</span>
      <span class="sep" aria-hidden="true">|</span>
      <span id="clima-dinamico">Lima: --°C</span>
    </div>
  </div>

  <!-- Banda del logo + buscador -->
  <div class="brand">
    <a href="/" aria-label="Libertario — Ir a portada">
      <span class="logo">Libertario</span>
    </a>
    <form action="/buscar/" method="get" role="search" class="search-box" id="search-form">
      <input
        type="search"
        name="q"
        id="search-input"
        placeholder="Buscar..."
        aria-label="Buscar en Libertario"
        autocomplete="off"
      />
      <button type="submit" aria-label="Buscar">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </form>
  </div>

  <!-- Barra de temas del día -->
  <nav class="temas" aria-label="Temas del día">
    <span class="temas-hoy">Hoy &rsaquo;</span>
    <a href="/titulares/">Titulares</a>
    <a href="/policiales/">Policiales</a>
    <a href="/actualidad/">Actualidad</a>
    <a href="/mundo/">Mundo</a>
  </nav>
</header>

<script>
  // ── 1. FECHA DINÁMICA (se actualiza en el cliente) ──
  function actualizarFecha() {
    const el = document.getElementById('fecha-dinamica');
    if (!el) return;
    const ahora = new Date();
    const fecha = ahora.toLocaleDateString('es-PE', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
    el.textContent = fecha;
  }
  actualizarFecha();

  // ── 2. CLIMA REAL DE LIMA (Open-Meteo, sin API key) ──
  async function cargarClima() {
    const el = document.getElementById('clima-dinamico');
    if (!el) return;
    try {
      // Lima: lat=-12.0464, lon=-77.0428
      const res = await fetch(
        'https://api.open-meteo.com/v1/forecast?latitude=-12.0464&longitude=-77.0428&current=temperature_2m,weathercode&timezone=America%2FLima'
      );
      if (!res.ok) throw new Error('Error clima');
      const data = await res.json();
      const temp = Math.round(data.current.temperature_2m);
      const code = data.current.weathercode;

      // Icono según código WMO
      let icono = '☀️';
      if (code >= 1 && code <= 3) icono = '⛅';
      if (code >= 51 && code <= 67) icono = '🌧️';
      if (code >= 80 && code <= 82) icono = '🌦️';
      if (code >= 95) icono = '⛈️';
      if (code === 45 || code === 48) icono = '🌫️';

      el.textContent = `Lima: ${temp}°C ${icono}`;
    } catch {
      el.textContent = 'Lima: --°C';
    }
  }
  cargarClima();

  // ── 3. BUSCADOR: redirige a /buscar/?q=término ──
  const form = document.getElementById('search-form');
  const input = document.getElementById('search-input') as HTMLInputElement;

  // Pre-llenar el input si hay búsqueda activa
  if (input) {
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q) input.value = q;
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = input?.value.trim();
    if (q) {
      window.location.href = `/buscar/?q=${encodeURIComponent(q)}`;
    }
  });
</script>

<style>
  /* ── Barra superior ── */
  .topnav {
    background: #d6d9e3;
    border-bottom: 1px solid #b0b5c5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    height: 36px;
  }

  .topnav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .topnav ul li a {
    display: block;
    padding: 8px 14px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #222;
    text-decoration: none;
  }

  .topnav ul li a:hover,
  .topnav ul li a[aria-current='page'] {
    color: #1a3f8f;
  }

  .topnav-right {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: #333;
    white-space: nowrap;
  }

  .sep { color: #999; }

  /* ── Banda logo + buscador ── */
  .brand {
    background: #1a3f8f;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 1rem;
  }

  .brand a { text-decoration: none; }

  .logo {
    font-family: 'Arial Black', sans-serif;
    font-style: italic;
    font-weight: 400;
    font-size: 3.25rem;
    color: #fff;
    letter-spacing: -1px;
    line-height: 1;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 2px;
    overflow: hidden;
    height: 36px;
    width: 240px;
  }

  .search-box input {
    border: none;
    outline: none;
    padding: 0 12px;
    font-size: 0.8125rem;
    flex: 1;
    height: 100%;
    color: #333;
    background: transparent;
  }

  .search-box button {
    background: #1a3f8f;
    border: none;
    width: 38px;
    height: 100%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.15s;
  }

  .search-box button:hover { background: #152f6e; }

  /* ── Barra de temas ── */
  .temas {
    background: #1e50b5;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    height: 34px;
    overflow-x: auto;
    gap: 0;
  }

  .temas-hoy {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    margin-right: 8px;
    white-space: nowrap;
  }

  .temas a {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    padding: 0 18px;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
    line-height: 34px;
    transition: background 0.15s;
  }

  .temas a:hover {
    color: #fff;
    background: rgba(0, 0, 0, 0.12);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .topnav ul { display: none; }
    .topnav { justify-content: flex-end; }
    .logo { font-size: 2.25rem; }
    .search-box { width: 160px; }
  }
</style>
