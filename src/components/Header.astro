---
import { mainNav, siteConfig, todayTopics } from '@/data/navigation';

const currentPath = Astro.url.pathname;

const dateLine = new Date().toLocaleDateString('es-PE', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formattedDate = dateLine.charAt(0).toUpperCase() + dateLine.slice(1);
---

<header class="border-b-2 border-black bg-white">
  <div class="border-b border-gray-200 bg-white">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-2 px-4 py-2 text-xs text-libertario-muted sm:px-6 lg:px-8">
      <time datetime={new Date().toISOString()}>{formattedDate}</time>
      <p>
        <span class="font-semibold text-libertario-dark">{siteConfig.city}:</span> 16°C
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="mx-auto block w-fit" aria-label="Libertario - Ir a portada">
      <img
        src={siteConfig.logo}
        alt={siteConfig.name}
        width="320"
        height="72"
        class="h-14 w-auto border-2 border-black sm:h-16"
        loading="eager"
      />
    </a>
  </div>

  <nav
    class="border-y border-gray-200 bg-libertario-cream"
    aria-label="Temas del día"
  >
    <div class="mx-auto flex max-w-7xl flex-wrap items-center gap-1 overflow-x-auto px-4 py-2 text-xs sm:px-6 lg:px-8">
      <span class="font-bold uppercase tracking-wide text-libertario-blue">Hoy</span>
      <span class="text-gray-400" aria-hidden="true">›</span>
      {
        todayTopics.map((topic) => (
          <a
            href={topic.href}
            class="whitespace-nowrap px-2 py-1 font-medium text-libertario-dark hover:text-libertario-blue"
          >
            {topic.label}
          </a>
        ))
      }
    </div>
  </nav>

  <nav class="bg-libertario-blue" aria-label="Secciones principales">
    <div class="mx-auto max-w-7xl overflow-x-auto px-4 sm:px-6 lg:px-8">
      <ul class="flex gap-0">
        {
          mainNav.map((item) => {
            const isActive =
              item.href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'block whitespace-nowrap border-r border-libertario-blue-dark/40 px-4 py-2.5 text-xs font-bold uppercase tracking-wider transition-colors last:border-r-0 sm:text-sm',
                    isActive
                      ? 'bg-white text-libertario-blue'
                      : 'text-white hover:bg-libertario-blue-dark',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </nav>
</header>
