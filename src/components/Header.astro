---
// src/components/Header.astro
 
const navLinks = [
  { href: '/titulares/', label: 'Titulares' },
  { href: '/policiales/', label: 'Policiales' },
  { href: '/actualidad/', label: 'Actualidad' },
  { href: '/mundo/', label: 'Mundo' },
  { href: '/mas/', label: 'Más' },
];
 
const currentPath = Astro.url.pathname;
 
const now = new Date();
const fecha = now.toLocaleDateString('es-PE', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
 
<header>
  <!-- Barra superior: nav + fecha/clima -->
  <div class="topnav">
    <nav aria-label="Secciones principales">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="topnav-right">
      <time datetime={now.toISOString()}>{fecha}</time>
      <span class="sep" aria-hidden="true">|</span>
      <span>Lima: 16°C</span>
    </div>
  </div>
 
  <!-- Banda del logo + buscador -->
  <div class="brand">
    <a href="/" aria-label="Libertario — Ir a portada">
      <span class="logo">Libertario</span>
    </a>
    <form action="/buscar/" method="get" role="search" class="search-box">
      <input
        type="search"
        name="q"
        placeholder="Buscar..."
        aria-label="Buscar en Libertario"
      />
      <button type="submit" aria-label="Buscar">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </form>
  </div>
 
  <!-- Barra de temas del día -->
  <nav class="temas" aria-label="Temas del día">
    <span class="temas-hoy">Hoy &rsaquo;</span>
    <a href="/titulares/">Titulares</a>
    <a href="/policiales/">Policiales</a>
    <a href="/actualidad/">Actualidad</a>
    <a href="/mundo/">Mundo</a>
  </nav>
</header>
 
<style>
  /* ── Barra superior ── */
  .topnav {
    background: #d6d9e3;
    border-bottom: 1px solid #b0b5c5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    height: 36px;
  }
 
  .topnav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }
 
  .topnav ul li a {
    display: block;
    padding: 8px 14px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #222;
    text-decoration: none;
  }
 
  .topnav ul li a:hover,
  .topnav ul li a[aria-current='page'] {
    color: #1a3f8f;
  }
 
  .topnav-right {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: #333;
  }
 
  .sep { color: #999; }
 
  /* ── Banda logo + buscador ── */
  .brand {
    background: #1a3f8f;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 1rem;
  }
 
  .brand a {
    text-decoration: none;
  }
 
  .logo {
    font-family: 'Arial Black', sans-serif;
    font-style: italic;
    font-weight: 400;
    font-size: 3.25rem;
    color: #fff;
    letter-spacing: -1px;
    line-height: 1;
  }
 
  .search-box {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 2px;
    overflow: hidden;
    height: 36px;
    width: 240px;
  }
 
  .search-box input {
    border: none;
    outline: none;
    padding: 0 12px;
    font-size: 0.8125rem;
    flex: 1;
    height: 100%;
    color: #333;
    background: transparent;
  }
 
  .search-box button {
    background: #1a3f8f;
    border: none;
    width: 38px;
    height: 100%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.15s;
  }
 
  .search-box button:hover {
    background: #152f6e;
  }
 
  /* ── Barra de temas ── */
  .temas {
    background: #1e50b5;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    height: 34px;
    overflow-x: auto;
    gap: 0;
  }
 
  .temas-hoy {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    margin-right: 8px;
    white-space: nowrap;
  }
 
  .temas a {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    padding: 0 18px;
    white-space: nowrap;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
    line-height: 34px;
    transition: background 0.15s;
  }
 
  .temas a:hover {
    color: #fff;
    background: rgba(0, 0, 0, 0.12);
  }
 
  /* ── Responsive: ocultar nav superior en móvil ── */
  @media (max-width: 640px) {
    .topnav ul { display: none; }
    .topnav { justify-content: flex-end; }
    .logo { font-size: 2.25rem; }
    .search-box { width: 160px; }
  }
</style>