---
import type { CollectionEntry } from 'astro:content';
import { getCategoryLabel } from '@/data/categories';
import type { Category } from '@/data/categories';

interface Props {
  article: CollectionEntry<'articulos'>;
}

const { article } = Astro.props;
const { title, description, pubDate, category, author, image } = article.data;
const href = `/articulo/${article.slug}/`;
---

<article class="overflow-hidden border-2 border-black bg-white">
  <a href={href} class="block">
    {
      image ? (
        <img
          src={image.src}
          alt={image.alt}
          class="aspect-[16/9] w-full border-b-2 border-black object-cover"
          loading="eager"
        />
      ) : (
        <div
          class="flex aspect-[16/9] w-full items-center justify-center border-b-2 border-black bg-libertario-blue/10 text-sm font-semibold uppercase tracking-widest text-libertario-blue"
          aria-hidden="true"
        >
          Imagen
        </div>
      )
    }

    <div class="p-5 md:p-8">
      <span class="mb-3 inline-block bg-libertario-blue px-3 py-1 text-xs font-bold tracking-widest text-white uppercase">
        Noticia 1 · {getCategoryLabel(category as Category)}
      </span>

      <h1 class="font-serif text-2xl font-bold leading-tight text-libertario-dark md:text-4xl">
        {title}
      </h1>

      <p class="mt-3 text-base leading-relaxed text-libertario-muted md:text-lg">
        {description}
      </p>

      <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-libertario-muted">
        <span>Por {author}</span>
        <span class="text-gray-300">|</span>
        <time datetime={pubDate.toISOString()}>
          {
            pubDate.toLocaleDateString('es-PE', {
              weekday: 'long',
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })
          }
        </time>
      </div>
    </div>
  </a>
</article>
